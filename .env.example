# Comma-separated list of "name=url" pairs — one entry per Jira saved filter.
# Each name becomes a URL path on the local server (e.g. /bugs, /releases).
# The URL is copied from Jira's Export > RSS menu.
#
# Example with two feeds:
# JIRA_FEEDS=bugs=https://yourcompany.atlassian.net/.../SearchRequest-111.xml?tempMax=1000,releases=https://yourcompany.atlassian.net/.../SearchRequest-222.xml?tempMax=1000
JIRA_FEEDS=bugs=https://yourcompany.atlassian.net/sr/jira.issueviews:searchrequest-rss/XXXXX/SearchRequest-XXXXX.xml?tempMax=1000,releases=https://yourcompany.atlassian.net/sr/jira.issueviews:searchrequest-rss/YYYYY/SearchRequest-YYYYY.xml?tempMax=1000

# Your Atlassian account email address
JIRA_EMAIL=you@example.com

# Atlassian API token — generate one at:
# https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your_api_token_here

# Local port for the proxy server (default: 8088)
PORT=8088

# How long (in seconds) to cache each upstream RSS response before re-fetching (default: 60)
CACHE_TTL_SECONDS=300
